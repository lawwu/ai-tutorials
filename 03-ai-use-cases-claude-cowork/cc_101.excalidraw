      "isDeleted": false,
      "boundElements": [],
      "updated": 1774999969526,
      "link": null,
      "locked": false,
      "text": "Coding Agents allow you to go DEEPER and BROADER",
      "fontSize": 24,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Coding Agents allow you to go DEEPER and BROADER",
