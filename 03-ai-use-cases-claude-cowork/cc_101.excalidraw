    {
      "id": "zZ6pGmWpS5BKdTbWNi-_Z",
      "type": "text",
      "x": -243.8306934793767,
      "y": -37.19714268250527,
      "width": 1141.1953125,
      "height": 401.68300781250036,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
